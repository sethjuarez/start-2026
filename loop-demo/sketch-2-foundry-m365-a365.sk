        "narrative": true,
        "demo_actions": true,
        "screenshot": true,
        "visual": true,
        "design_plan": true
      },
      "time": "~30s",
      "narrative": "- From there, the agent becomes easier for the business to use.\n- People do not have to open a builder tool.\n- Invoice assurance can show up where they already work, including Teams through M365 or A365.",
      "demo_actions": "Move to the M365 or A365 surface. Show the autopilot or agent entry point in Teams.",
      "screenshot": ".cutready/screenshots/20260622_212932_145_14.jpg"
    },
