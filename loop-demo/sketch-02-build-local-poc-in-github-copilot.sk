      },
      "time": "~35s",
      "narrative": "- Here is the first invoice-review agent.\n- Its job is narrow on purpose.\n- It compares invoice lines with contract language and supporting operating records.\n- It checks what was billed against what was contracted, delivered, released, and approved.",
      "demo_actions": "Open the canvas. Show the agent configuration, task definition, and model choice.",
      "screenshot": ".cutready/screenshots/20260617_112228_CleanShot 2026-06-17 at 11.18.47@2x.png"
    },
    {
      "locked": false,
      "locks": {
