{
  "title": "Observe - Governance and Cost in A365",
  "locked": false,
  "description": "Broader operating chapter in A365 that widens the view from one agent run to the full governed fleet, including approvals, access, auditability, and cost.",
  "rows": [
    {
      "locked": false,
      "locks": {
