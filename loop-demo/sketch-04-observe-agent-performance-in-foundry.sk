        "design_plan": false
      },
      "time": "~30s",
      "narrative": "- Start with tracing.\n- The point is to see the path through the evidence.\n- Which records did the agent read?\n- Which steps did it take before making a recommendation?\n- That gives the team a concrete view into each run.",
      "demo_actions": "Open trace details for an invoice-review run. Show the sequence of evidence access and reasoning steps.",
      "screenshot": null
    },
    {
      "locked": false,
      "locks": {
        "time": false,
        "narrative": false,
        "demo_actions": false,
        "screenshot": false,
        "visual": false,
        "design_plan": false
      },
      "time": "~30s",
      "narrative": "- Then move into rubrics.\n- Keep them grounded in the real job.\n- Are we reasoning correctly over contract terms?\n- Are we using the right evidence?\n- Is the recommendation clear and defensible?",
      "demo_actions": "Open Foundry rubric evaluators. Show criteria tied to contract reasoning, evidence use, and recommendation quality.",
      "screenshot": ".cutready/screenshots/20260622_143122_vlcsnap-2026-06-22-14h31m17s909.png"
    },
    {
      "locked": false,
