        "narrative": false,
        "demo_actions": false,
        "screenshot": false,
        "visual": false,
        "design_plan": false
      },
      "time": "~30s",
      "narrative": "- Run evaluations against those rubrics.\n- See where the agent is strong.\n- See where it still needs work.\n- This gives the team a repeatable way to improve quality instead of relying on anecdotal testing.",
      "demo_actions": "Run or review evaluation results. Show scores, failures, and examples.",
