        "narrative": false,
        "demo_actions": false,
        "screenshot": false,
        "visual": false,
        "design_plan": false
      },
      "time": "~35s",
      "narrative": "- Keep the rubrics grounded in the task.\n- Are we reasoning correctly over contract terms?\n- Are we using the right evidence from receipts, batch records, quality status, and milestone approvals?\n- Is the recommendation clear and defensible?",
      "demo_actions": "Show the generated rubrics. Highlight criteria tied to contract reasoning, evidence use, and recommendation quality.",
      "screenshot": ".cutready/screenshots/20260622_143122_vlcsnap-2026-06-22-14h31m17s909.png"
    },
    {
      "locked": false,
