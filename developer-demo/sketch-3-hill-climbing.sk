        "design_plan": false
      },
      "time": "~35s",
      "narrative": "Those rubrics stay grounded in the task. Are we reasoning correctly over contract terms? Are we using the right evidence from receipts, batch records, quality status, and milestone approvals? Is the recommendation clear and defensible?",
      "demo_actions": "Show the generated rubrics. Highlight criteria tied to contract reasoning, evidence use, and recommendation quality.",
      "screenshot": null
    },
